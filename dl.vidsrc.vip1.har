            "text": "{\"movie_results\":[],\"person_results\":[],\"tv_results\":[{\"adult\":false,\"backdrop_path\":\"/qji729gwCW88RpIIWidlaLTul3V.jpg\",\"id\":252,\"name\":\"Everybody Hates Chris\",\"original_name\":\"Everybody Hates Chris\",\"overview\":\"Chris is a teenager growing up as the eldest of three children in Brooklyn, New York during the early 1980s. Uprooted to a new neighborhood and bused to a predominantly white middle school two-hours away by his strict, hard-working parents, Chris struggles to find his place while keeping his siblings in line at home and surmounting the challenges of junior high.\",\"poster_path\":\"/zX0xZnyReJxtGAqDOS3WcsgpOgx.jpg\",\"media_type\":\"tv\",\"original_language\":\"en\",\"genre_ids\":[35],\"popularity\":12.2805,\"first_air_date\":\"2005-09-22\",\"vote_average\":8.066,\"vote_count\":1086,\"origin_country\":[\"US\"]}],\"tv_episode_results\":[],\"tv_season_results\":[]}"
