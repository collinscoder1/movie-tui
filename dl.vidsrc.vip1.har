            "text": "{\"_id\":\"5253489b19c29579400e28c4\",\"air_date\":\"2005-09-22\",\"episodes\":[{\"air_date\":\"2005-09-22\",\"episode_number\":1,\"episode_type\":\"standard\",\"id\":13895,\"name\":\"Everybody Hates The Pilot\",\"overview\":\"Uprooted to a new neighborhood and bussed to a predominantly white middle school two-hours away by his strict, hard-working parents, Chris struggles to find his place while keeping his siblings in line at home and dealing with the school bully, Joey.\",\"production_code\":\"101\",\"runtime\":21,\"season_number\":1,\"show_id\":252,\"still_path\":\"/pV7Tdi55X82u0fmuu20gRxVsSYc.jpg\",\"vote_average\":7.5,\"vote_count\":51,\"crew\":[{\"department\":\"Directing\",\"job\":\"Director\",\"credit_id\":\"525348b619c29579400e3937\",\"adult\":false,\"gender\":2,\"id\":68215,\"known_for_department\":\"Directing\",\"name\":\"Reginald Hudlin\",\"original_name\":\"Reginald Hudlin\",\"popularity\":0.7827,\"profile_path\":\"/z2O30pOwkKpZBCyZpwZ80ouKcQA.jpg\"},{\"job\":\"Teleplay\",\"department\":\"Writing\",\"credit_id\":\"66abeb70cafe2a3cc3f8e052\",\"adult\":false,\"gender\":2,\"id\":59164,\"known_for_department\":\"Production\",\"name\":\"Ali LeRoi\",\"original_name\":\"Ali LeRoi\",\"popularity\":0.68,\"profile_path\":\"/x5HSFOPjRyjfe62cpXdwQ5tkT2u.jpg\"},{\"job\":\"Story\",\"department\":\"Writing\",\"credit_id\":\"66abeb87b9e67e4bee82d33e\",\"adult\":false,\"gender\":2,\"id\":59164,\"known_for_department\":\"Production\",\"name\":\"Ali LeRoi\",\"original_name\":\"Ali LeRoi\",\"popularity\":0.68,\"profile_path\":\"/x5HSFOPjRyjfe62cpXdwQ5tkT2u.jpg\"},{\"job\":\"Story\",\"department\":\"Writing\",\"credit_id\":\"66abeb8ddc7202362aa3b46d\",\"adult\":false,\"gender\":2,\"id\":2632,\"known_for_department\":\"Acting\",\"name\":\"Chris Rock\",\"original_name\":\"Chris Rock\",\"popularity\":2.8252,\"profile_path\":\"/cqI8yQ00GNDV3PAAz5UeLj7vOX0.jpg\"}],\"guest_stars\":[{\"character\":\"Bus Driver\",\"credit_id\":\"525348b519c29579400e38f3\",\"or