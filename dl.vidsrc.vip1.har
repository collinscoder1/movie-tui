          "cookies": [],
          "content": {
            "size": 3470,
            "mimeType": "application/json",
            "text": "{\"adult\":false,\"backdrop_path\":\"/qji729gwCW88RpIIWidlaLTul3V.jpg\",\"created_by\":[{\"id\":2632,\"credit_id\":\"525348d719c29579400e48f7\",\"name\":\"Chris Rock\",\"original_name\":\"Chris Rock\",\"gender\":2,\"profile_path\":\"/cqI8yQ00GNDV3PAAz5UeLj7vOX0.jpg\"},{\"id\":59164,\"credit_id\":\"525348d719c29579400e48fd\",\"name\":\"Ali LeRoi\",\"original_name\":\"Ali LeRoi\",\"gender\":2,\"profile_path\":\"/x5HSFOPjRyjfe62cpXdwQ5tkT2u.jpg\"}],\"episode_run_time\":[],\"first_air_date\":\"2005-09-22\",\"genres\":[{\"id\":35,\"name\":\"Comedy\"}],\"homepage\":\"http://www.everybodyhateschris.com/\",\"id\":252,\"in_production\":false,\"languages\":[\"en\"],\"last_air_date\":\"2009-05-08\",\"last_episode_to_air\":{\"id\":13952,\"name\":\"Everybody Hates G.E.D.\",\"overview\":\"It's the last week of school and while Drew decides he wants to try out for Amateur Night at the Apollo even without a talent at his disposal, Chris is informed that if he gets one more tardy he will have to repeat the 10th grade. But one day he misses the bus and arrives at school late, forcing him to deliver the bad news to his parents.\",\"vote_average\":8.5,\"vote_count\":2,\"air_date\":\"2009-05-08\",\"episode_number\":22,\"episode_type\":\"finale\",\"production_code\":\"422\",\"runtime\":22,\"season_number\":4,\"show_id\":252,\"still_path\":null},\"name\":\"Everybody Hates Chris\",\"next_episode_to_air\":null,\"networks\":[{\"id\":40,\"logo_path\":\"/333LtWX9Z7H9uRrNcCl1JcTvdpR.png\",\"name\":\"UPN\",\"origin_country\":\"US\"},{\"id\":71,\"logo_path\":\"/hEpcdJ4O6eitG9ADSnDXNUrlovS.png\",\"name\":\"The CW\",\"origin_country\":\"US\"}],\"number_of_episodes\":88,\"number_of_seasons\":4,\"origin_country\":[\"US\"],\"original_language\":\"en\",\"original_name\":\"Everybody Hates Chris\",\"overview\":\"Chris is a teenager growing up as the eldest of three children in Brooklyn, New York during the early 1980s. Uprooted to a new neighborhood and bused to a predominantly white middle school two-hours away by his strict, hard-working parents, Chris struggles to find his place while keeping his siblings in line at home and surmounting the challenges of junior high.\",\"popularity\":12.2805,\"poster_path\":\"/zX0xZnyReJxtGAqDOS3WcsgpOgx.jpg\",\"production_companies\":[{\"id\":160859,\"logo_path\":null,\"name\":\"Chris Rock Entertainment\",\"origin_country\":\"US\"},{\"id\":787,\"logo_path\":\"/cCefBs1t7jxtiz3eCxBp9yxrxGx.png\",\"name\":\"3 Arts Entertainment\",\"origin_country\":\"US\"},{\"id\":9223,\"logo_path\":\"/40qzTBM38vokoWhLKurficZ5syV.png\",\"name\":\"Paramount Television\",\"origin_country\":\"US\"},{\"id\":1081,\"logo_path\":\"/19kn4jVvpc3sAL3YpZNb3elhSMl.png\",\"name\":\"CBS Studios\",\"origin_country\":\"US\"}],\"production_countries\":[{\"iso_3166_1\":\"US\",\"name\":\"United States of America\"}],\"seasons\":[{\"air_date\":\"2005-09-22\",\"episode_count\":22,\"id\":809,\"name\":\"Season 1\",\"overview\":\"\",\"poster_path\":\"/kWhuuR2NIEXp4mDR3VIdWVJSdgf.jpg\",\"season_number\":1,\"vote_average\":7.7},{\"air_date\":\"2006-10-01\",\"episode_count\":22,\"id\":810,\"name\":\"Season 2\",\"overview\":\"\",\"poster_path\":\"/e28wcIlN6dnFBNEPJJSPaVgpTvd.jpg\",\"season_number\":2,\"vote_average\":7.5},{\"air_date\":\"2007-10-01\",\"episode_count\":22,\"id\":808,\"name\":\"Season 3\",\"overview\":\"\",\"poster_path\":\"/6xFTjxeNm6gfNGs2roAlrsqnclJ.jpg\",\"season_number\":3,\"vote_average\":7.4},{\"air_date\":\"2008-10-03\",\"episode_count\":22,\"id\":811,\"name\":\"Season 4\",\"overview\":\"\",\"poster_path\":\"/3v9JOQKY0H7mhk76Tk8xa4Rm883.jpg\",\"season_number\":4,\"vote_average\":7.7}],\"spoken_languages\":[{\"english_name\":\"English\",\"iso_639_1\":\"en\",\"name\":\"English\"}],\"status\":\"Ended\",\"tagline\":\"Get ready to ROCK\",\"type\":\"Scripted\",\"vote_average\":8.066,\"vote_count\":1086}"
